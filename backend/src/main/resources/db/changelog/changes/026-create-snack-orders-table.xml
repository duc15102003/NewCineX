<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="026" author="cinex">

        <!-- Bảng snack_orders: đơn hàng POS tại quầy -->
        <createTable tableName="snack_orders">
            <!-- BaseEntity fields -->
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="storage_state" type="NVARCHAR(20)"/>
            <column name="created_by" type="NVARCHAR(50)"/>
            <column name="updated_by" type="NVARCHAR(50)"/>
            <column name="created_at" type="DATETIME2"/>
            <column name="updated_at" type="DATETIME2"/>
            <!-- SnackOrder fields -->
            <column name="order_code" type="NVARCHAR(30)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="total_amount" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
            <column name="note" type="NVARCHAR(200)"/>
        </createTable>

        <!-- Bảng snack_order_items: chi tiết từng món trong đơn -->
        <createTable tableName="snack_order_items">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="snack_order_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="snack_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <!-- Lưu giá tại thời điểm bán, không dùng giá hiện tại của snack -->
            <column name="price" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="snack_order_items"
                baseColumnNames="snack_order_id"
                referencedTableName="snack_orders"
                referencedColumnNames="id"
                constraintName="fk_snack_order_items_order"/>

        <addForeignKeyConstraint
                baseTableName="snack_order_items"
                baseColumnNames="snack_id"
                referencedTableName="snacks"
                referencedColumnNames="id"
                constraintName="fk_snack_order_items_snack"/>

        <!-- IdTracker cho SNACK order code: VD "SNACK-20260527-001" -->
        <insert tableName="id_tracker">
            <column name="entity_type" value="SNACK"/>
            <column name="prefix" value="SNACK"/>
            <column name="current_value" value="0"/>
            <column name="description" value="Snack POS order code: SNACK-20260527-001"/>
        </insert>

    </changeSet>

</databaseChangeLog>
