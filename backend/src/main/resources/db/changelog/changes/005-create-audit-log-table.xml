<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005" author="cinex">
        <createTable tableName="audit_log">
            <!-- No BaseEntity -->
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="table_name" type="NVARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="record_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="field_name" type="NVARCHAR(50)"/>
            <column name="old_value" type="NVARCHAR(500)"/>
            <column name="new_value" type="NVARCHAR(500)"/>
            <column name="changed_by" type="NVARCHAR(50)"/>
            <column name="changed_at" type="DATETIME2" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="audit_log" indexName="idx_audit_log_table_record">
            <column name="table_name"/>
            <column name="record_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
