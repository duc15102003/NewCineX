<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Engagement: reviews, user_favorites, notifications, loyalty_transactions -->

    <changeSet id="006-create-reviews" author="cinex">
        <createTable tableName="reviews">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="storage_state" type="NVARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="NVARCHAR(100)"/>
            <column name="updated_by" type="NVARCHAR(100)"/>
            <column name="created_at" type="DATETIME2" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME2" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="movie_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="rating" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="NVARCHAR(MAX)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="reviews" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_reviews_user"/>
        <addForeignKeyConstraint baseTableName="reviews" baseColumnNames="movie_id"
                                 referencedTableName="movies" referencedColumnNames="id"
                                 constraintName="fk_reviews_movie"/>
        <createIndex tableName="reviews" indexName="idx_reviews_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="reviews" indexName="idx_reviews_movie_id">
            <column name="movie_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="006-create-user-favorites" author="cinex">
        <createTable tableName="user_favorites">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="storage_state" type="NVARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="NVARCHAR(100)"/>
            <column name="updated_by" type="NVARCHAR(100)"/>
            <column name="created_at" type="DATETIME2" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME2" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="movie_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="user_favorites" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_user_favorites_user"/>
        <addForeignKeyConstraint baseTableName="user_favorites" baseColumnNames="movie_id"
                                 referencedTableName="movies" referencedColumnNames="id"
                                 constraintName="fk_user_favorites_movie"/>
        <addUniqueConstraint tableName="user_favorites" columnNames="user_id, movie_id"
                             constraintName="uq_user_favorites_user_movie"/>
    </changeSet>

    <changeSet id="006-create-notifications" author="cinex">
        <createTable tableName="notifications">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="storage_state" type="NVARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="NVARCHAR(100)"/>
            <column name="updated_by" type="NVARCHAR(100)"/>
            <column name="created_at" type="DATETIME2" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME2" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="NVARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="NVARCHAR(MAX)"/>
            <column name="type" type="NVARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="is_read" type="BIT" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="notifications" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_notifications_user"/>
        <createIndex tableName="notifications" indexName="idx_notifications_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="notifications" indexName="idx_notifications_is_read">
            <column name="is_read"/>
        </createIndex>
    </changeSet>

    <changeSet id="006-create-loyalty-transactions" author="cinex">
        <createTable tableName="loyalty_transactions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="storage_state" type="NVARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="NVARCHAR(100)"/>
            <column name="updated_by" type="NVARCHAR(100)"/>
            <column name="created_at" type="DATETIME2" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME2" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="booking_id" type="BIGINT"/>
            <column name="transaction_type" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="points" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="balance_after" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="NVARCHAR(500)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="loyalty_transactions" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_loyalty_transactions_user"/>
        <addForeignKeyConstraint baseTableName="loyalty_transactions" baseColumnNames="booking_id"
                                 referencedTableName="bookings" referencedColumnNames="id"
                                 constraintName="fk_loyalty_transactions_booking"/>
        <createIndex tableName="loyalty_transactions" indexName="idx_loyalty_transactions_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
