<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="016" author="cinex">
        <createTable tableName="reviews">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="storage_state" type="NVARCHAR(20)"/>
            <column name="created_by" type="NVARCHAR(50)"/>
            <column name="updated_by" type="NVARCHAR(50)"/>
            <column name="created_at" type="DATETIME2"/>
            <column name="updated_at" type="DATETIME2"/>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="movie_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="rating" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="NTEXT"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="reviews" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_reviews_user_id"/>
        <addForeignKeyConstraint baseTableName="reviews" baseColumnNames="movie_id"
                                 referencedTableName="movies" referencedColumnNames="id"
                                 constraintName="fk_reviews_movie_id"/>
        <addUniqueConstraint tableName="reviews" columnNames="user_id, movie_id"
                             constraintName="uq_reviews_user_movie"/>
        <createIndex tableName="reviews" indexName="idx_reviews_movie_id">
            <column name="movie_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
