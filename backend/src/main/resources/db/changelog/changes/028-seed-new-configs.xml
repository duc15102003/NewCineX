<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="028-seed-new-configs" author="cinex">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM system_config WHERE config_key = 'booking.cutoff_after_start_minutes'
            </sqlCheck>
        </preConditions>

        <insert tableName="system_config">
            <column name="config_key" value="booking.cutoff_after_start_minutes"/>
            <column name="config_value" value="15"/>
            <column name="description" value="Cho đặt vé trong X phút sau khi suất chiếu bắt đầu (thời gian quảng cáo/trailer)"/>
        </insert>
        <insert tableName="system_config">
            <column name="config_key" value="booking.cancel_before_minutes"/>
            <column name="config_value" value="60"/>
            <column name="description" value="Hủy vé trước X phút khi suất chiếu bắt đầu"/>
        </insert>
        <insert tableName="system_config">
            <column name="config_key" value="auth.reset_token_expiry_minutes"/>
            <column name="config_value" value="15"/>
            <column name="description" value="Token đặt lại mật khẩu hết hạn sau X phút"/>
        </insert>
    </changeSet>

</databaseChangeLog>
