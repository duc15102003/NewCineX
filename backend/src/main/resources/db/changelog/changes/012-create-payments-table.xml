<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="012" author="cinex">
        <createTable tableName="payments">
            <!-- BaseEntity -->
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="storage_state" type="NVARCHAR(20)"/>
            <column name="created_by" type="NVARCHAR(50)"/>
            <column name="updated_by" type="NVARCHAR(50)"/>
            <column name="created_at" type="DATETIME2"/>
            <column name="updated_at" type="DATETIME2"/>

            <!-- Payment fields -->
            <column name="booking_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="amount" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
            <column name="method" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="transaction_code" type="NVARCHAR(100)"/>
            <column name="status" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="paid_at" type="DATETIME2"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="payments" baseColumnNames="booking_id"
                                 referencedTableName="bookings" referencedColumnNames="id"
                                 constraintName="fk_payments_booking_id"/>
    </changeSet>

</databaseChangeLog>
