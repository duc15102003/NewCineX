<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="009" author="cinex">
        <createTable tableName="seats">
            <!-- BaseEntity -->
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="storage_state" type="NVARCHAR(20)"/>
            <column name="created_by" type="NVARCHAR(50)"/>
            <column name="updated_by" type="NVARCHAR(50)"/>
            <column name="created_at" type="DATETIME2"/>
            <column name="updated_at" type="DATETIME2"/>

            <!-- Seat fields -->
            <column name="room_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="row_label" type="NVARCHAR(5)">
                <constraints nullable="false"/>
            </column>
            <column name="col_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="seat_number" type="NVARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="seat_type" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="seats" baseColumnNames="room_id"
                                 referencedTableName="rooms" referencedColumnNames="id"
                                 constraintName="fk_seats_room_id"/>
        <createIndex tableName="seats" indexName="idx_seats_room_id">
            <column name="room_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
