<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="019" author="cinex">
        <createTable tableName="user_favorites">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="movie_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME2"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="user_favorites" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_user_favorites_user_id"/>
        <addForeignKeyConstraint baseTableName="user_favorites" baseColumnNames="movie_id"
                                 referencedTableName="movies" referencedColumnNames="id"
                                 constraintName="fk_user_favorites_movie_id"/>
        <addUniqueConstraint tableName="user_favorites" columnNames="user_id, movie_id"
                             constraintName="uq_user_favorites_user_movie"/>
    </changeSet>

</databaseChangeLog>
