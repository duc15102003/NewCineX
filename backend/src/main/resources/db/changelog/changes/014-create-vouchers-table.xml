<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="014" author="cinex">
        <createTable tableName="vouchers">
            <!-- BaseEntity -->
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="storage_state" type="NVARCHAR(20)"/>
            <column name="created_by" type="NVARCHAR(50)"/>
            <column name="updated_by" type="NVARCHAR(50)"/>
            <column name="created_at" type="DATETIME2"/>
            <column name="updated_at" type="DATETIME2"/>

            <!-- Voucher fields -->
            <column name="code" type="NVARCHAR(30)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="NVARCHAR(255)"/>
            <column name="discount_type" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="discount_value" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
            <column name="min_order_amount" type="DECIMAL(12,0)" defaultValueNumeric="0"/>
            <column name="max_discount" type="DECIMAL(12,0)"/>
            <column name="usage_limit" type="INT"/>
            <column name="used_count" type="INT" defaultValueNumeric="0"/>
            <column name="start_date" type="DATETIME2">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="DATETIME2">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BIT" defaultValueBoolean="true"/>
        </createTable>

        <!-- Bảng lưu user nào đã dùng voucher nào (tránh dùng nhiều lần) -->
        <createTable tableName="voucher_usages">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="voucher_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="booking_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="used_at" type="DATETIME2">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="voucher_usages" baseColumnNames="voucher_id"
                                 referencedTableName="vouchers" referencedColumnNames="id"
                                 constraintName="fk_voucher_usages_voucher_id"/>
        <addForeignKeyConstraint baseTableName="voucher_usages" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_voucher_usages_user_id"/>
        <addForeignKeyConstraint baseTableName="voucher_usages" baseColumnNames="booking_id"
                                 referencedTableName="bookings" referencedColumnNames="id"
                                 constraintName="fk_voucher_usages_booking_id"/>
        <!-- 1 user chỉ dùng 1 voucher 1 lần -->
        <addUniqueConstraint tableName="voucher_usages" columnNames="voucher_id, user_id"
                             constraintName="uq_voucher_user"/>
    </changeSet>

</databaseChangeLog>
