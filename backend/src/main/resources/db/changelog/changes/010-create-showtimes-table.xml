<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="010" author="cinex">
        <createTable tableName="showtimes">
            <!-- BaseEntity -->
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="storage_state" type="NVARCHAR(20)"/>
            <column name="created_by" type="NVARCHAR(50)"/>
            <column name="updated_by" type="NVARCHAR(50)"/>
            <column name="created_at" type="DATETIME2"/>
            <column name="updated_at" type="DATETIME2"/>

            <!-- Showtime fields -->
            <column name="movie_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="room_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="DATETIME2">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="DATETIME2">
                <constraints nullable="false"/>
            </column>
            <column name="base_price" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
            <column name="vip_price" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
            <column name="couple_price" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="showtimes" baseColumnNames="movie_id"
                                 referencedTableName="movies" referencedColumnNames="id"
                                 constraintName="fk_showtimes_movie_id"/>
        <addForeignKeyConstraint baseTableName="showtimes" baseColumnNames="room_id"
                                 referencedTableName="rooms" referencedColumnNames="id"
                                 constraintName="fk_showtimes_room_id"/>
        <createIndex tableName="showtimes" indexName="idx_showtimes_movie_id">
            <column name="movie_id"/>
        </createIndex>
        <createIndex tableName="showtimes" indexName="idx_showtimes_room_start">
            <column name="room_id"/>
            <column name="start_time"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
