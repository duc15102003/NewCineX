<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="017" author="cinex">
        <createTable tableName="snacks">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="storage_state" type="NVARCHAR(20)"/>
            <column name="created_by" type="NVARCHAR(50)"/>
            <column name="updated_by" type="NVARCHAR(50)"/>
            <column name="created_at" type="DATETIME2"/>
            <column name="updated_at" type="DATETIME2"/>

            <column name="name" type="NVARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="NVARCHAR(255)"/>
            <column name="price" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
            <column name="image_url" type="NVARCHAR(500)"/>
            <column name="category" type="NVARCHAR(50)"/>
            <column name="available" type="BIT" defaultValueBoolean="true"/>
        </createTable>

        <createTable tableName="booking_snacks">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="booking_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="snack_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="booking_snacks" baseColumnNames="booking_id"
                                 referencedTableName="bookings" referencedColumnNames="id"
                                 constraintName="fk_booking_snacks_booking_id"/>
        <addForeignKeyConstraint baseTableName="booking_snacks" baseColumnNames="snack_id"
                                 referencedTableName="snacks" referencedColumnNames="id"
                                 constraintName="fk_booking_snacks_snack_id"/>
    </changeSet>

</databaseChangeLog>
