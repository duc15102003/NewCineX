<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="011" author="cinex">
        <createTable tableName="bookings">
            <!-- BaseEntity -->
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="storage_state" type="NVARCHAR(20)"/>
            <column name="created_by" type="NVARCHAR(50)"/>
            <column name="updated_by" type="NVARCHAR(50)"/>
            <column name="created_at" type="DATETIME2"/>
            <column name="updated_at" type="DATETIME2"/>

            <!-- Booking fields -->
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="showtime_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="booking_code" type="NVARCHAR(30)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="confirmed_at" type="DATETIME2"/>
            <column name="cancelled_at" type="DATETIME2"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="bookings" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_bookings_user_id"/>
        <addForeignKeyConstraint baseTableName="bookings" baseColumnNames="showtime_id"
                                 referencedTableName="showtimes" referencedColumnNames="id"
                                 constraintName="fk_bookings_showtime_id"/>
        <createIndex tableName="bookings" indexName="idx_bookings_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="bookings" indexName="idx_bookings_booking_code">
            <column name="booking_code"/>
        </createIndex>

        <!-- booking_seats (no BaseEntity) -->
        <createTable tableName="booking_seats">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="booking_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="seat_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(12,0)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="booking_seats" baseColumnNames="booking_id"
                                 referencedTableName="bookings" referencedColumnNames="id"
                                 constraintName="fk_booking_seats_booking_id"/>
        <addForeignKeyConstraint baseTableName="booking_seats" baseColumnNames="seat_id"
                                 referencedTableName="seats" referencedColumnNames="id"
                                 constraintName="fk_booking_seats_seat_id"/>
    </changeSet>

</databaseChangeLog>
